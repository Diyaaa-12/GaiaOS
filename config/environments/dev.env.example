# Development environment — copy to repo root as .env for local overrides.
# Placeholder values only; no secrets.

GAIAOS_ENV=dev
LOG_LEVEL=DEBUG

# Host-run Python connecting to Postgres published on localhost (see docker-compose.override.yml.example).
# When the app runs inside Docker Compose, docker-compose.yml overrides DATABASE_URL to use host "postgres".
DATABASE_URL=postgresql://gaiaos:your-dev-password-here@localhost:5432/gaiaos

# LLM model selection (defaults to gpt-4o-mini)
LLM_MODEL=gpt-4o-mini

